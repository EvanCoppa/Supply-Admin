{
  "name": "supply-admin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "svelte-kit sync && tsc --noEmit && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "db:types": "supabase gen types typescript --local > src/lib/types/db.generated.ts",
    "db:types:check": "scripts/check-db-types.sh",
    "migrations:apply": "scripts/apply-migrations.sh",
    "ci:verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@lucide/svelte": "^1.9.0",
    "@playwright/test": "^1.49.0",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.6",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "clsx": "^2.1.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.0",
    "zod": "^3.25.76"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
